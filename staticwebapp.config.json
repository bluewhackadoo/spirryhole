{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.html", "*.css", "*.js", "*.png", "*.jpg", "*.svg", "*.ico"]
  },
  "routes": [
    { "route": "/about", "rewrite": "/about.html" },
    { "route": "/submit", "rewrite": "/submit.html" }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/index.html", "statusCode": 200 }
  },
  "globalHeaders": {
    "X-Powered-By": "classified",
    "X-Node": "spirryhole-primary",
    "Cache-Control": "no-cache"
  }
}
